{
	"info": {
		"_postman_id": "c98f8287-c1c0-4389-9a2c-f3e1b0c03dc7",
		"name": "W6_AuthAPICollection_TBI-26101025",
		"description": "Week 6 Deliverable 3: Authentication API Collection for SentiNest (Homestay Review Classifier). Includes register, login (auto-saves JWT as environment variable), and 2 protected endpoint requests.",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "Auth",
			"description": "Authentication endpoints: Register and Login. Run Login first to auto-populate the jwt_token environment variable before testing protected routes.",
			"item": [
				{
					"name": "Register User",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Status code is 200\", function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"pm.test(\"Response has user email\", function () {",
									"    var jsonData = pm.response.json();",
									"    pm.expect(jsonData).to.have.property('email');",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"email\": \"testuser_w6@example.com\",\n    \"password\": \"securepassword123\"\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{base_url}}/api/auth/register",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"api",
								"auth",
								"register"
							]
						},
						"description": "Registers a new user account with an email and hashed password. Returns the created user object. Duplicate emails return 400."
					},
					"response": []
				},
				{
					"name": "Login User",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Status code is 200\", function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"pm.test(\"Response contains access_token\", function () {",
									"    var jsonData = pm.response.json();",
									"    pm.expect(jsonData).to.have.property('access_token');",
									"});",
									"// Auto-save JWT as an environment variable",
									"var jsonData = pm.response.json();",
									"if (jsonData.access_token) {",
									"    pm.environment.set(\"jwt_token\", jsonData.access_token);",
									"    console.log(\"JWT Token saved to environment variable: jwt_token\");",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"email\": \"testuser_w6@example.com\",\n    \"password\": \"securepassword123\"\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{base_url}}/api/auth/login",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"api",
								"auth",
								"login"
							]
						},
						"description": "Validates credentials and returns a signed JWT access token. The test script automatically saves the token as the 'jwt_token' environment variable for use in protected routes below."
					},
					"response": []
				},
				{
					"name": "Logout (Clear Token)",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"// Clear the JWT from the environment on logout",
									"pm.environment.unset(\"jwt_token\");",
									"console.log(\"jwt_token cleared from environment.\");"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{jwt_token}}"
							},
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"url": {
							"raw": "{{base_url}}/api/auth/logout",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"api",
								"auth",
								"logout"
							]
						},
						"description": "Logs out the current user. The test script automatically clears the jwt_token environment variable."
					},
					"response": []
				}
			]
		},
		{
			"name": "Protected Routes",
			"description": "These requests require authentication. Run 'Login User' first to auto-populate the jwt_token. All requests use Bearer token auth from the environment variable.",
			"item": [
				{
					"name": "Get All Sessions (Protected)",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Status code is 200\", function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"pm.test(\"Response is an array\", function () {",
									"    pm.expect(pm.response.json()).to.be.an('array');",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"auth": {
							"type": "bearer",
							"bearer": [
								{
									"key": "token",
									"value": "{{jwt_token}}",
									"type": "string"
								}
							]
						},
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/api/sessions",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"api",
								"sessions"
							]
						},
						"description": "PROTECTED. Returns all review audit sessions for the logged-in user. Requires a valid JWT Bearer token. Returns 401 if no token is provided."
					},
					"response": []
				},
				{
					"name": "Search Reviews by Sentiment (Protected)",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Status code is 200\", function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"pm.test(\"Response is an array\", function () {",
									"    pm.expect(pm.response.json()).to.be.an('array');",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"auth": {
							"type": "bearer",
							"bearer": [
								{
									"key": "token",
									"value": "{{jwt_token}}",
									"type": "string"
								}
							]
						},
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/api/reviews/search?sentiment=positive",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"api",
								"reviews",
								"search"
							],
							"query": [
								{
									"key": "sentiment",
									"value": "positive",
									"description": "Filter by sentiment: positive | neutral | negative"
								},
								{
									"key": "q",
									"value": "",
									"description": "Optional: keyword search in review text",
									"disabled": true
								},
								{
									"key": "theme",
									"value": "",
									"description": "Optional: filter by theme e.g. host, cleanliness, food",
									"disabled": true
								}
							]
						},
						"description": "PROTECTED. Searches classified reviews filtered by sentiment and/or keyword. Requires a valid JWT Bearer token. Returns 401 if no token is provided."
					},
					"response": []
				}
			]
		},
		{
			"name": "Rate Limit Test (429)",
			"description": "Send this request rapidly 10+ times to trigger the rate limiter and get a 429 Too Many Requests response.",
			"item": [
				{
					"name": "Trigger Rate Limit on Login",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Rate limit triggered (expect 200 or 429)\", function () {",
									"    pm.expect(pm.response.code).to.be.oneOf([200, 429]);",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"email\": \"wronguser@example.com\",\n    \"password\": \"wrongpassword\"\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{base_url}}/api/auth/login",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"api",
								"auth",
								"login"
							]
						},
						"description": "Hit 'Send' rapidly 10+ times. After several attempts, the rate limiter will respond with HTTP 429 Too Many Requests. Use this to capture the 429 screenshot for Deliverable 2."
					},
					"response": []
				}
			]
		}
	],
	"variable": [
		{
			"key": "base_url",
			"value": "http://localhost:8000",
			"type": "string",
			"description": "Base URL for local development. Change to your production URL for live testing."
		},
		{
			"key": "jwt_token",
			"value": "",
			"type": "string",
			"description": "Auto-populated by the Login User request test script. Do not edit manually."
		}
	]
}
