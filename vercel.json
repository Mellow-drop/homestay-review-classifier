{
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.py"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "functions": {
    "api/index.py": {
      "excludeFiles": "{node_modules/**,client/node_modules/**,dist/**,client/dist/**,attached_assets/**}"
    }
  }
}
